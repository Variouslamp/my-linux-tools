### --- VARIABLES DE ENTORNO (NVIDIA) ---
set $mod Mod4

## --- SIEMPRE EJECUTAR AL INICIO DE LA SESION ---
exec_always autotiling
exec swww-daemon
exec wal -R -n
exec swaync
exec mpd-mpris
exec kdeconnect-indicator
exec wl-paste --type text --watch cliphist store
exec rclone mount gdrive: ~/Drive --vfs-cache-mode full
exec waybar
exec_always bash -c "~/.scripts/sistema/wstart"

# Variables para que Sway se lleve bien con tu ASUS TUF
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway
exec systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP

### --- CONFIGURACIÓN DE ENTRADA (Latam) ---
input "type:keyboard" {
    xkb_layout latam
}

input "type:touchpad" {
    tap enabled
    natural_scroll disabled
    dwt enabled
}

# Configuración específica de tu teclado (según tu log de Hyprland)
input "at-translated-set-2-keyboard" {
    events enabled
}

### --- ESTÉTICA (Gaps y Bordes) de sway nativo no de swayfx---
gaps inner 6
gaps outer 8
client.focused #585b70 #585b70 #ffffff #585b70 #585b70
client.unfocused #2a2b36 #2a2b36 #888888 #2a2b36 #2a2b36

### --- ATAJOS DE TECLADO (Binds) ---

# Atajos del sistema
bindsym $mod+Shift+s exec swaymsg reload

# Aplicaciones principales
bindsym $mod+a exec rofi -show drun
bindsym $mod+q exec bash -c "~/my-tools/scripts/sistema/fterm"
bindsym $mod+t exec kitty
bindsym $mod+e exec kitty yazi
bindsym $mod+c kill
bindsym $mod+Shift+space floating toggle
bindsym $mod+Shift+w exec "~/my-tools/scripts/sistema/autofondo"
bindsym $mod+w exec "~/my-tools/scripts/rofi/wallpaper-select.sh"
bindsym $mod+f fullscreen toggle
bindsym $mod+b exec firefox
bindsym $mod+r exec wmctrl -a ferdium || ferdium

floating_modifier $mod
# Captura de pantalla (Grim + Slurp)
bindsym Print exec grim -g "$(slurp)" - | tee ~/Imagenes/ScreenShots/$(date +'%Y-%m-%d_%H%M%S').png | wl-copy

# Navegación (Flechas)
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Mover ventanas
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Redimensionar (Resize)
bindsym $mod+Control+Left resize shrink width 20 px
bindsym $mod+Control+Right resize grow width 20 px
bindsym $mod+Control+Up resize shrink height 20 px
bindsym $mod+Control+Down resize grow height 20 px

# Workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

# Mover a Workspaces
bindsym $mod+Shift+1 move container to workspace number 1; workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2; workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3; workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4; workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5; workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6; workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7; workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8; workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9; workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10; workspace number 10



# Extras
bindsym $mod+j layout toggle split
bindsym $mod+n exec swaync-client -t -sw
bindsym $mod+Shift+n exec swaync-client -C
bindsym $mod+Shift+r exec killall -SIGINT gpu-screen-recorder && notify-send "Recording Stopped"

# Audio (Teclas F y Multimedia)
bindsym XF86AudioMute exec amixer set Master toggle
bindsym XF86AudioLowerVolume exec amixer set Master 1%-
bindsym XF86AudioRaiseVolume exec amixer set Master 1%+

### --- REGLAS DE VENTANA ---
for_window [class="mpv"] floating enable
for_window [class="mpv"] resize set 640 360
for_window [class="scratchterm"] floating enable
for_window [class="scratchterm"] resize set 85 ppt 70 ppt

### --- SALIR DE SWAY ---
bindsym $mod+Shift+e exec swaynag -t warning -m '¿Quieres salir de Sway?' -b 'Sí, salir' 'swaymsg exit'

# Evitar cerrar la barra o el fondo por accidente
for_window [app_id="waybar"] floating_enable, border none, sticky enable
for_window [class="swww-daemon"] floating_enable, border none
for_window [app_id="swaync"] floating_enable, border none


# --- COMPORTAMIENTO DE VENTANAS ---

for_window [app_id="popup-.*"] floating enable, resize set width 800 height 400, move position center
for_window [app_id="float-term"] floating enable, resize set width 800 height 400, move position center

# ventanas de inicio
for_window [app_id="start-clock"] floating enable, move position 1000 40
for_window [app_id="start-cow"] floating enable, move position -110 400, resize set 300 260
for_window [app_id="start-fetch"] floating enable, move position 1000 500, resize set 750 300
for_window [app_id="start-tube"] floating enable, move position 10 10, resize set 800 400

# --- Configuración Visual SwayFX ---

# 1. Bordes redondeados
corner_radius 20
# 2. Transparencia en ventanas inactivas
default_dim_inactive 0.2
# 3. Quita bordes de ventanas 
default_border none
default_floating_border none
# 4. Activa el efecto de desenfoque
blur enable
   # Ajusta la intensidad (0-10) y el número de pasadas (0-10)
blur_radius 5
blur_passes 2
   # Configuracion de transparencia de waybar
layer_effects "waybar" blur enable; corner_radius 10
